# OpenAI-compatible chat completions endpoint.
# DeepSeek example:
# MODEL_BASE_URL=https://api.deepseek.com
# MODEL_NAME=deepseek-v4-pro
# MODEL_API_KEY=sk-...

MODEL_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-v4-pro
MODEL_API_KEY=

# Used to sign login tokens. Set a long random value in production.
AUTH_SECRET=0

# Comma-separated frontend origins allowed by CORS.
# Add your production frontend domain/IP here.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://8.163.11.131

# SQLite database path. Relative paths are resolved from backend/.
DATABASE_PATH=data/arborlearn.sqlite3

# Optional web search provider. Set one of the keys below to enable search.
# WEB_SEARCH_PROVIDER=auto
# TAVILY_API_KEY=tvly-...
# BRAVE_SEARCH_API_KEY=...
# SEARXNG_BASE_URL=http://127.0.0.1:8080

# RAG Configuration
# Enable RAG (Retrieval-Augmented Generation)
ENABLE_RAG=true

# Vector database path. Relative paths are resolved from backend/.
VECTOR_DB_PATH=data/lancedb

# Embedding model for vector search
# Options: all-MiniLM-L6-v2, all-mpnet-base-v2, etc.
VECTOR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# OCR Configuration (for image uploads)
ENABLE_OCR=true
OCR_LANGUAGES=chi_sim+eng
# Windows example:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
OCR_TIMEOUT_SECONDS=12

# Vision / multimodal parsing configuration
# none | openai_compatible | qwen_vl
VISION_PROVIDER=none
# For local Qwen2.5-VL OpenAI-compatible service
VISION_BASE_URL=http://127.0.0.1:8001/v1
VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VISION_API_KEY=
VISION_TIMEOUT_SECONDS=120
VISION_MAX_ATTEMPTS=4
VISION_RETRY_INITIAL_DELAY_SECONDS=2
VISION_RETRY_MAX_DELAY_SECONDS=12
VISION_MAX_IMAGE_EDGE=2400
