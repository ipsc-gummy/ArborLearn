# OpenAI-compatible chat completions endpoint.
# DeepSeek example:
# MODEL_BASE_URL=https://api.deepseek.com
# MODEL_NAME=deepseek-v4-pro
# MODEL_API_KEY=sk-...

MODEL_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-v4-pro
MODEL_API_KEY=

# Used to sign login tokens. Set a long random value in production.
AUTH_SECRET=0

# Email verification and password reset links.
EMAIL_VERIFICATION_REQUIRED=true
FRONTEND_BASE_URL=http://127.0.0.1:5173
BACKEND_BASE_URL=http://127.0.0.1:8000
SMTP_HOST=smtpdm.aliyun.com
SMTP_PORT=465
SMTP_USER=no-reply@arborlearn.top
SMTP_PASSWORD=
SMTP_FROM=no-reply@arborlearn.top
SMTP_FROM_NAME=ArborLearn
EMAIL_CODE_SECRET=
# Development-only: set DEBUG_EMAIL_CODES=true to log generated codes locally.
DEBUG_EMAIL_CODES=false

# GitHub OAuth login. Callback URL defaults to:
# ${BACKEND_BASE_URL}/api/auth/oauth/github/callback
# GitHub OAuth App client IDs often start with Ov... (capital letter O), not 0v... (digit zero).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# GITHUB_OAUTH_CALLBACK_URL=https://api.example.com/api/auth/oauth/github/callback

# Optional admin account. Leave ADMIN_PASSWORD empty to disable auto-creation.
ADMIN_EMAIL=example@arborlearn.top
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Administrator

# Wallet defaults. Amounts are in RMB cents; 1000 = ¥10.00.
DEFAULT_WALLET_INITIAL_CENTS=1000

# Admin wallet defaults apply to all users with is_admin=1.
ADMIN_WALLET_INITIAL_CENTS=1000

# Used to convert built-in official USD model prices into RMB cents.
# 7.20 means 1 USD = 7.20 CNY.
USD_TO_CNY_RATE=7.20

# Comma-separated frontend origins allowed by CORS.
# Add your production frontend domain/IP here.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://8.163.11.131

# SQLite database path. Relative paths are resolved from backend/.
DATABASE_PATH=data/arborlearn.sqlite3

# Optional web search provider. Set one of the keys below to enable search.
# WEB_SEARCH_PROVIDER=auto
# TAVILY_API_KEY=tvly-...
# BRAVE_SEARCH_API_KEY=...
# SEARXNG_BASE_URL=http://127.0.0.1:8080

# RAG Configuration
# Enable RAG (Retrieval-Augmented Generation)
ENABLE_RAG=true

# Vector database path. Relative paths are resolved from backend/.
VECTOR_DB_PATH=data/lancedb

# Embedding model for vector search
# Options: all-MiniLM-L6-v2, all-mpnet-base-v2, etc.
VECTOR_EMBEDDING_MODEL=all-MiniLM-L6-v2

# OCR Configuration (for image uploads)
ENABLE_OCR=true
OCR_LANGUAGES=chi_sim+eng
# Windows example:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
OCR_TIMEOUT_SECONDS=12

# Vision / multimodal parsing configuration
# none | openai_compatible | qwen_vl
VISION_PROVIDER=none
# For local Qwen2.5-VL OpenAI-compatible service
VISION_BASE_URL=http://127.0.0.1:8001/v1
VISION_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VISION_API_KEY=
VISION_TIMEOUT_SECONDS=120
VISION_MAX_ATTEMPTS=4
VISION_RETRY_INITIAL_DELAY_SECONDS=2
VISION_RETRY_MAX_DELAY_SECONDS=12
VISION_MAX_IMAGE_EDGE=2400
