# OpenAI-compatible chat completions endpoint.
# DeepSeek example:
# MODEL_BASE_URL=https://api.deepseek.com
# MODEL_NAME=deepseek-v4-flash
# MODEL_API_KEY=sk-...

MODEL_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-v4-flash
MODEL_API_KEY=

# Used to sign login tokens. Set a long random value in production.
AUTH_SECRET=change-this-before-production

# Comma-separated frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SQLite database path. Relative paths are resolved from backend/.
DATABASE_PATH=data/treelearn.sqlite3
