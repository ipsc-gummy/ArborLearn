[Unit]
Description=ArborLearn FastAPI backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/arborlearn/backend
EnvironmentFile=/opt/arborlearn/backend/.env
ExecStart=/opt/arborlearn/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
